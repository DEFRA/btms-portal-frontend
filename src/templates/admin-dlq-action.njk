{% extends 'layout.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% set pageTitle = "Admin - Dead letter actions" %}

{% block content %}
  <div class="govuk-tabs btms-admin-tabs">
    <ul class="govuk-tabs__list" role="tablist">
      <li class="govuk-tabs__list-item govuk-tabs__list-item--selected" role="presentation">
        <a class="btms-admin-dlq__tab" href="#">Dead Letter</a>
      </li>
      <li class="govuk-tabs__list-item govuk-tabs__list-item" role="presentation">
        <a class="btms-admin-dlq__tab" href="/admin/messages">Messages</a>
      </li>
    </ul>
    <section class="btms-admin-dlq-tabs__panel" role="tabpanel">
      <h1 class="govuk-heading-l govuk-!-margin-top-6">Dead letter actions</h1>
      <div class="btms-admin-dlq__action">
        <div class="govuk-inset-text">
          There are currently {{ action.queueCount }} dead letter messages in the {{ action.queueGroup }} queue - {{ action.actionQueue }}
        </div>

        {% if action.queueCount > 0 %}
          <p>Clicking on Redrive messages will queue the messages for re-processing</p>
          <p>Clicking on Drain messages from queue will remove all the messages from the queue</p>

          <form id="redrive" method="post" action="/admin/dlq/action" class="btms-admin-action__confirm">
            {{ govukButton({
              text: "Redrive messages",
              classes: "govuk-button--warning",
              preventDoubleClick: true
            }) }}
            <input type="hidden" name="confirmActionQueue" value="{{ action.actionQueue }}" />
            <input type="hidden" name="confirmAction" value="Redrive" />
          </form>
          <form id="drain" method="post" action="/admin/dlq/action" class="btms-admin-action__confirm">
            {{ govukButton({
              text: "Drain messages from queue",
              classes: "govuk-button--warning btms-admin-drain__request",
              preventDoubleClick: true
            }) }}
            <input type="hidden" name="confirmActionQueue" value="{{ action.actionQueue }}" />
            <input type="hidden" name="confirmAction" value="Drain" />
          </form>

          <p>There may be a slight delay before the Dead Letter Queue shows as empty, this is to be expected.</p>
        {% endif %}

        {{ govukBackLink({
        text: "Back",
        href: "/admin/dlq"
        }) }}
      </div>
    </section>
  </div>
{% endblock %}
