{% extends 'layout.njk' %}

{% from "govuk/components/tabs/macro.njk" import govukTabs %}

{% set pageTitle = "Admin" %}

{% set dlqView %}
{% include "./includes/admin-dlq.njk" %}
{% endset %}
{% set messagesView %}
{% include "./includes/admin-search.njk" %}
{% endset %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {{ govukTabs({
        classes: 'btms-admin-tabs',
        items: [
          {
            label: 'Dead Letter',
            id: 'dlq-view',
            panel: {
              html: dlqView
            }
          },
          {
            label: 'Messages',
            id: 'messages-view',
            panel: {
              html: messagesView
            }
          }
        ]
      }) }}
    </div>
  </div>
{% endblock %}
{% block bodyEnd %}
  {{ super() }}
  <script src="{{ getAssetPath('admin.js') }}"></script>
{% endblock %}
