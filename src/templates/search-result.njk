{% extends 'layout.njk' %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = "Showing result for " ~ searchTerm %}

{% set latestView %}
{% include "./includes/search-result-latest.njk" %}
{% endset %}
{% set timelineView %}
{% include "./includes/search-result-timeline.njk" %}
{% endset %}
{% set levelsView %}
{% include "./includes/search-result-levels.njk" %}
{% endset %}

{% set bannerTextHtml = [] %}
{% if showLevel2NoMatchText %}
  {% set bannerTextHtml = (bannerTextHtml.push('<p>If level 2 matching was applied, this declaration would not be released. At least one commodity code on this customs declaration is not listed on the CHED.</p>'), bannerTextHtml) %}
{% endif %}
{% if showLevel3NoMatchText %}
  {% set bannerTextHtml = (bannerTextHtml.push('<p>If level 3 matching was applied, this declaration would not be released. The declared weight or quantity on at least one item does not match the CHED.</p>'), bannerTextHtml) %}
{% endif %}

{% set resultsTabs = [
  {
    label: 'Latest',
    id: 'latest-view',
    panel: {
      html: latestView
    }
  },
  {
    label: 'Timeline',
    id: 'timeline-view',
    panel: {
      html: timelineView
    }
  }
] %}
{% if showLevelsResultTab %}
  {% set bannerTextHtml = (bannerTextHtml.push('<a href="#levels-view">View L2/L3 result</a>'), bannerTextHtml) %}

  {% set resultsTabs = (resultsTabs.push({
    label: 'L2/L3 Result',
    id: 'levels-view',
    panel: {
     html: levelsView
    }
  }), resultsTabs) %}
{% endif %}

{% block content %}
  <div class="govuk-grid-row btms-search-results">
    <div class="govuk-grid-column-full">
      <div class="btms-heading-container">
        <h1 class="govuk-heading-l">
          <span class="govuk-caption-l">Showing result for</span>{{ searchTerm }}
        </h1>
      </div>
      {% if showLevel2NoMatchText or showLevel3NoMatchText %}
        {{ govukNotificationBanner({
            html: bannerTextHtml | join,
            classes: 'btms-level-no-match-banner'
          })
        }}
      {% endif %}
      {{ govukTabs({
        classes: 'btms-tabs',
        items: resultsTabs
      }) }}
    </div>
  </div>
{% endblock %}
{% block bodyEnd %}
  {{ super() }}
  <script src="{{ getAssetPath('searchResult.js') }}"></script>
  <script nonce="{{ cspNonce }}">
    BTMS.initFilters()
  </script>
{% endblock %}
