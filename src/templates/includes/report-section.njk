{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "../macros/tiles.njk" import tiles %}

<section aria-labelledBy="{{ report.type }}-summary-heading" class="govuk-grid-row govuk-!-margin-bottom-6 btms-report">
  <div class="govuk-grid-column-full">
    <heading>
      <h3 id="{{ report.type }}-summary-heading" class="govuk-heading-m">{{ report.heading }}</h3>
      {% if descriptions[report.type] %}
        <p class="govuk-body-s">{{ descriptions[report.type] }}</p>
      {% endif %}
    </heading>
    {{ tiles(report.tiles, downloadUrls) }}

    {% if report.regionSplits %}
      {% set regionSplitTiles %}
      {% include "./region-split-tiles.njk" %}
      {% endset %}
      {{
          govukDetails({
            summaryText: regionSplitSummaryText[report.type],
            html: regionSplitTiles,
            open: false,
            classes: 'btms-level-region-split__details'
          })
        }}
    {% endif %}
  </div>
</section>
